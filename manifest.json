{
  "manifest_version": 3,
  "name": "Brink",
  "version": "1.0.2",
  "description": "Event countdown extension with live overlay and notifications",

  "browser_specific_settings": {
    "gecko": {
      "id": "{52802364-3a8c-4769-8965-78e904f2fad3}",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "121.0"
    }
  },

  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["overlay.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Brink - Event Countdown"
  },
  "icons": {
    "128": "icon.png"
  }
}
